# ==========================================
# Core Environments & Sensitive Keys (CRITICAL)
# ==========================================
# Blocks the backend .env, frontend .env, and any root backups
.env
.env.*
!.env.example

# ==========================================
# Python Backend Targets
# ==========================================
# Blocks the virtual environment regardless of where it is named or placed
.venv/
venv/
ENV/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# ==========================================
# React Frontend Targets
# ==========================================
# Blocks the heavy production node dependency trees
node_modules/
dist/
build/
. Dan_store
.eslintcache

# ==========================================
# System Specific Files
# ==========================================
.DS_Store
Thumbs.db